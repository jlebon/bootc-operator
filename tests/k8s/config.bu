variant: fcos
version: 1.6.0
storage:
  files:
    # Disable ZRAM swap
    - path: /etc/systemd/zram-generator.conf
      mode: 0644
      contents:
        inline: ""
    # Flannel requires bridge netfilter to filter traffic crossing Linux bridges
    - path: /etc/modules-load.d/kubernetes.conf
      mode: 0644
      contents:
        inline: |
          br_netfilter
    # Kubernetes requires IP forwarding for pod-to-pod traffic across nodes,
    # and bridge netfilter so iptables rules apply to bridged traffic
    - path: /etc/sysctl.d/99-kubernetes.conf
      mode: 0644
      contents:
        inline: |
          net.ipv4.ip_forward = 1
          net.bridge.bridge-nf-call-iptables = 1
    - path: /etc/kubernetes/kubeadm.conf
      mode: 0644
      contents:
        inline: |
          apiVersion: kubeadm.k8s.io/v1beta4
          kind: InitConfiguration
          nodeRegistration:
            criSocket: unix:///run/crio/crio.sock
          ---
          apiVersion: kubeadm.k8s.io/v1beta4
          kind: ClusterConfiguration
          networking:
            # Must match the default in Flannel's net-conf.json
            podSubnet: 10.244.0.0/16
          controllerManager:
            extraArgs:
              # The kube-controller-manager always mounts the flex volume plugin dir
              # (even though FlexVolume is deprecated in favor of CSI). The default
              # path is under /usr which is read-only on FCOS, so redirect it.
              # This can be dropped in kubeadm v1.36. See:
              # https://github.com/kubernetes/kubernetes/pull/136423
              - name: flex-volume-plugin-dir
                value: /var/lib/kubelet/volumeplugins
          ---
          apiVersion: kubelet.config.k8s.io/v1beta1
          kind: KubeletConfiguration
          volumePluginDir: /var/lib/kubelet/volumeplugins
    # Flannel CNI manifest
    - path: /etc/kubernetes/flannel.yml
      mode: 0644
      contents:
        source: "https://github.com/flannel-io/flannel/releases/latest/download/kube-flannel.yml"
    # Tell CRI-O to also look in /usr/libexec/cni for CNI plugins (where
    # the containernetworking-plugins RPM installs them). Also include
    # /opt/cni/bin where Flannel's init container copies its plugin.
    - path: /etc/crio/crio.conf.d/10-cni.conf
      mode: 0644
      contents:
        inline: |
          [crio.network]
          plugin_dirs = ["/opt/cni/bin", "/usr/libexec/cni"]
    # Shell alias and completions
    - path: /etc/profile.d/kubernetes.sh
      mode: 0644
      contents:
        inline: |
          alias k=kubectl
          source <(kubectl completion bash)
          complete -o default -F __start_kubectl k
systemd:
  units:
    # Mount the host's /mnt into the VM via virtiofs. This is always
    # present (virtiofsd always runs); the contents depend on what the
    # user bind-mounted into /mnt on the container.
    - name: var-mnt.mount
      enabled: true
      contents: |
        [Unit]
        Description=Mount host /mnt via virtiofs

        [Mount]
        What=hostmnt
        Where=/var/mnt
        Type=virtiofs

        [Install]
        WantedBy=multi-user.target
    - name: kubelet.service
      enabled: true
      contents: |
        [Unit]
        Description=kubelet: The Kubernetes Node Agent
        Documentation=https://kubernetes.io/docs/
        Wants=network-online.target
        Requires=crio.service
        After=network-online.target crio.service

        [Service]
        ExecStartPre=/usr/bin/mkdir -p /var/lib/kubelet /var/lib/kubelet/volumeplugins
        ExecStart=/usr/bin/kubelet --kubeconfig=/etc/kubernetes/kubelet.conf --config=/var/lib/kubelet/config.yaml --container-runtime-endpoint=unix:///run/crio/crio.sock
        Restart=always
        StartLimitInterval=0
        RestartSec=10

        [Install]
        WantedBy=multi-user.target
    - name: kubeadm-bootstrap.service
      enabled: true
      contents: |
        [Unit]
        Description=Bootstrap Kubernetes Single Node
        # Only run on first boot; kubeadm init creates admin.conf
        ConditionPathExists=!/etc/kubernetes/admin.conf
        After=kubelet.service

        [Service]
        Type=oneshot
        RemainAfterExit=true
        ExecStart=/usr/bin/kubeadm init --config=/etc/kubernetes/kubeadm.conf
        # Allow scheduling workloads on the control plane (single-node cluster)
        ExecStart=/usr/bin/kubectl --kubeconfig=/etc/kubernetes/admin.conf taint nodes --all node-role.kubernetes.io/control-plane-
        ExecStart=/usr/bin/mkdir -p /home/core/.kube
        ExecStart=/usr/bin/cp /etc/kubernetes/admin.conf /home/core/.kube/config
        ExecStart=/usr/bin/chown -R core:core /home/core/.kube
        ExecStart=/usr/bin/kubectl --kubeconfig=/etc/kubernetes/admin.conf apply -f /etc/kubernetes/flannel.yml

        [Install]
        WantedBy=multi-user.target
    # FCOS uses a strict signature verification policy. Rewrite the ostree
    # origin file to use the unverified transport so that bootc/rpm-ostree
    # can pull test images without signature checks.
    - name: fix-ostree-origin.service
      enabled: true
      contents: |
        [Unit]
        Description=Use unverified registry transport in ostree origin

        [Service]
        Type=oneshot
        RemainAfterExit=true
        ExecStart=/usr/bin/bash -c 'mount -o remount,rw /sysroot && sed -i s/ostree-image-signed/ostree-unverified-registry/ /ostree/deploy/fedora-coreos/deploy/*.origin; mount -o remount,ro /sysroot'

        [Install]
        WantedBy=multi-user.target
